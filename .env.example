# --- Akamai AI Inference Cloud (OpenAI-compatible) ---
# Get these from the Akamai table / workshop at the venue.
# Works against ANY OpenAI-compatible endpoint so you can build before creds arrive
# (e.g. local ollama: AKAMAI_BASE_URL=http://localhost:11434 , key can be blank).
AKAMAI_BASE_URL=
AKAMAI_API_KEY=
MODEL_FAST=            # small/fast model id (does the bulk of the tokens)
MODEL_SMART=           # large/smart model id (runs once to plan Magnific params)

# Rough $/Mtok constants for the cost ledger (pitch visual; estimates are fine).
COST_FAST_PER_MTOK=0.10
COST_SMART_PER_MTOK=1.00

# --- Magnific engines: set ONE provider key ---
# Route B (direct, api.magnific.com): magnific.com -> Settings -> Organization -> API Keys
MAGNIFIC_API_KEY=
# Route A (via Freepik, api.freepik.com): freepik.com -> API dashboard
FREEPIK_API_KEY=
# MAGNIFIC_API_KEY takes priority if both are set. Base URLs are overridable:
# MAGNIFIC_BASE_URL=https://api.magnific.com
# FREEPIK_BASE_URL=https://api.freepik.com

# --- Budget / safety ---
MAX_MAGNIFIC_CALLS_PER_RUN=6
LIVE_MAX_UPSCALE=4x    # live runs cap at 4x; 8x money-shot lives in DEMO_MODE cache

# --- Demo ---
DEMO_MODE=0            # 1 = replay a cached run instantly (venue Wi-Fi insurance)

# Public base for exported feed image links (Shopify/Google/Meta importers fetch
# images server-side — localhost links won't import). Point at any public host
# of backend/, e.g. this repo's raw base:
# PUBLIC_ASSET_BASE=https://raw.githubusercontent.com/Kush614/Adbox/main/backend
